# ------------------------------------------------------------------
# Meridiana — variáveis de ambiente (copie para .env e preencha)
# ------------------------------------------------------------------

# --- App ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Persistence ---
# memory = in-memory (rápido, demo). prisma = Postgres real.
DB_MODE=memory
DATABASE_URL=postgresql://meridiana:meridiana@localhost:5432/meridiana

# --- Auth ---
# ATENÇÃO: troque o JWT_SECRET em produção (use: openssl rand -base64 48)
JWT_SECRET=dev-only-jwt-secret-32bytes-minimum-please-change-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
AUTH_COOKIE_NAME=meridiana_refresh
AUTH_COOKIE_SECURE=false
BCRYPT_COST=12

# --- Adapters externos ---
CFM_ADAPTER=mock
CFM_REVERIFY_DAYS=30

ICP_BRASIL_ADAPTER=mock
ICP_BRASIL_VIDAAS_BASE_URL=
ICP_BRASIL_CLIENT_ID=
ICP_BRASIL_CLIENT_SECRET=

WHATSAPP_ADAPTER=mock
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

LIVEKIT_ADAPTER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

GOVBR_RDC660_ADAPTER=mock
GOVBR_BASE_URL=
GOVBR_API_TOKEN=

BILLING_ADAPTER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAGARME_API_KEY=

# --- AI providers (cheap-first routing) ---
# Gemini é o default para tarefas estruturadas (M1, M4, M8)
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.5-flash-lite
GEMINI_MODEL_VISION=gemini-2.5-flash

# OpenAI usado para tarefas de texto longo cacheável (M2, M9)
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o

# Llama local (PII redaction) — Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PII=llama3.1:8b

# Whisper self-hosted (transcrição)
WHISPER_BASE_URL=http://localhost:9000

# --- Budget guard ---
AI_BUDGET_BRL_PER_PATIENT_MONTH=2.50
AI_BUDGET_HARD_STOP_BRL_PER_PATIENT_MONTH=3.00

# --- DB / Cache ---
DATABASE_URL=postgresql://meridiana:meridiana@localhost:5432/meridiana
REDIS_URL=redis://localhost:6379

# --- Compliance ---
DPO_EMAIL=dpo@meridiana.health
LGPD_DATA_RESIDENCY=BR
