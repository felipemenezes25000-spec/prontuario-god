{
  "name": "meridiana",
  "version": "0.0.1",
  "private": true,
  "description": "Prontuário inteligente vertical para cannabis medicinal no Brasil — IA em todas as camadas, LGPD-by-design.",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @meridiana/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/engines", "@prisma/client", "prisma", "sharp"]
  }
}
